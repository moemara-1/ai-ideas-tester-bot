# Data Source: reddit or hackernews (hackernews requires no API keys!)
DATA_SOURCE=hackernews

# Code Generator: openrouter or opencode
# - openrouter: Use OpenRouter API (requires OPENROUTER_API_KEY)
# - opencode: Use OpenCode CLI with MiniMax M2.5 Free (no API key required)
# Install OpenCode: curl -fsSL https://opencode.ai/install | bash
CODE_GENERATOR=opencode

# LLM / AI (required only if CODE_GENERATOR=openrouter)
# Get free key from https://openrouter.ai/
# Available free models: deepseek/deepseek-chat:free, minimax/minimax-m2.5:free, meta-llama/llama-3-1-8b-instruct:free
# OPENROUTER_API_KEY=
# OPENROUTER_FREE_MODEL_ALLOWLIST=deepseek/deepseek-chat:free,minimax/minimax-m2.5:free,meta-llama/llama-3-1-8b-instruct:free,google/gemini-2.0-flash-exp:free

# Application URL (used for OpenRouter API referer header)
APP_URL=http://localhost:3000

# Data + queue
DATABASE_URL=file:./dev.db
REDIS_URL=redis://localhost:6379

# Reddit - for discovering AI ideas (only required if DATA_SOURCE=reddit)
# Get from https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=AIIdeaIntelligence/1.0

# Code execution (optional - for sandboxed execution)
# DOCKER_ENABLED=false
# DOCKER_HOST=
