# LLM / AI
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL_ALLOWLIST=google/gemini-2.0-flash-exp:free,meta-llama/llama-3-8b-instruct:free,deepseek/deepseek-chat:free

# Application URL (used for OpenRouter API referer header)
APP_URL=http://localhost:3000

# Data + queue
DATABASE_URL=file:./dev.db
REDIS_URL=redis://localhost:6379

# Reddit - for discovering AI ideas
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AIIdeaIntelligence/1.0

# Code execution (optional - for sandboxed execution)
# DOCKER_ENABLED=false
# DOCKER_HOST=
